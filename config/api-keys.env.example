# ===========================================
# API Keys Configuration
# ===========================================
# このファイルをコピーして api-keys.env にリネームし、
# 実際のAPIキーを設定してください。
# api-keys.env は .gitignore に追加し、絶対にGitにコミットしないでください。
# ===========================================

# --- Claude API (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# --- Threads API (Meta) ---
THREADS_ACCESS_TOKEN=xxxxxxxxxxxxx
THREADS_USER_ID=xxxxxxxxxxxxx

# --- X (Twitter) API ---
X_API_KEY=xxxxxxxxxxxxx
X_API_SECRET=xxxxxxxxxxxxx
X_ACCESS_TOKEN=xxxxxxxxxxxxx
X_ACCESS_TOKEN_SECRET=xxxxxxxxxxxxx
X_BEARER_TOKEN=xxxxxxxxxxxxx

# --- Optional: Gemini API (Google) ---
# GEMINI_API_KEY=xxxxxxxxxxxxx
